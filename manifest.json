{
  "manifest_version": 2,
  "name": "EdControls Zen Tools",
  "version": "1.0.0",
  "description": "Developer tools for EdControls — command palette with quick actions.",
  "icons": {
    "48": "icons/icon.svg",
    "96": "icons/icon.svg"
  },
  "permissions": [
    "cookies",
    "clipboardWrite",
    "activeTab",
    "*://*.edcontrols.com/*"
  ],
  "background": {
    "scripts": ["background.js"]
  },
  "content_scripts": [
    {
      "matches": ["*://*.edcontrols.com/*"],
      "js": ["content.js"],
      "css": [],
      "run_at": "document_idle"
    }
  ],
  "commands": {
    "open-command-palette": {
      "suggested_key": {
        "default": "Ctrl+K",
        "mac": "Command+K"
      },
      "description": "Open command palette"
    }
  },
  "web_accessible_resources": [
    "command-palette.css"
  ],
  "browser_specific_settings": {
    "gecko": {
      "id": "zen-tools@edcontrols.com",
      "strict_min_version": "109.0"
    }
  }
}
